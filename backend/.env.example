# Database
MAIN_DB_HOST=localhost
MAIN_DB_NAME=main_db
MAIN_DB_USER=postgres
MAIN_DB_PASSWORD=postgres
MAIN_DB_PORT=5432

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Third-party credential at-rest encryption (urlsafe-base64 Fernet key).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production (ENV=production); in dev a missing key falls back to
# plaintext storage with a loud warning.
CREDENTIAL_ENCRYPTION_KEY=
